# All configuration for the stack lives here, including passwords -- the
# subject requires a .env file and treats Docker secrets as a recommendation
# rather than a hard requirement, so this project keeps things to one file.
# Copy this file to srcs/.env, then change every value below (especially the
# passwords) before running `make`.

# ---- Global ----
# Must resolve to this host's IP on the machine you run the stack from
# (e.g. via /etc/hosts: "127.0.0.1 kabouelf.42.fr").
DOMAIN_NAME=kabouelf.42.fr

# ---- MariaDB ----
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=WpDbUserChangeMe!2026
MYSQL_ROOT_PASSWORD=MariaDbRootChangeMe!2026

# ---- WordPress ----
WP_TITLE=Inception
# Must NOT contain admin/Admin/administrator/Administrator (subject requirement).
WP_ADMIN_USER=kbf_owner
WP_ADMIN_EMAIL=kabouelf@student.42.fr
WP_ADMIN_PASSWORD=WpAdminChangeMe!2026
WP_USER=kbf_writer
WP_USER_EMAIL=writer@kabouelf.42.fr
WP_USER_PASSWORD=WpUserChangeMe!2026
